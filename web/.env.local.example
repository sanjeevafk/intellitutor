# Gemini API Configuration
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
SUMMARY_TEMPERATURE=0.2
SUMMARY_MAX_TOKENS=256

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=your-upstash-redis-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token
SUMMARY_RATE_LIMIT=10
SUMMARY_RATE_WINDOW="1 h"

# Testing Toggles (1 to bypass APIs during development/testing)
GEMINI_TEST_MODE=0
RATE_LIMIT_TEST_MODE=0

# Google OAuth 2.0 Credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Turso SQLite Database Configuration
# Local SQLite database path: file:local.db
# Production/Edge database path: libsql://your-db.turso.io
TURSO_DATABASE_URL=file:local.db
TURSO_AUTH_TOKEN=your-turso-auth-token

# Custom JWT Authentication
JWT_SECRET=your-secure-jwt-secret-min-32-characters

# Public App URL (where the application is hosted)
# Local development: http://localhost:3000
# Production: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
